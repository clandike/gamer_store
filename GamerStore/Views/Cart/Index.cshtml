@model CartViewModel

@{
    this.Layout = "_CartLayout";
}

<style>
    /* Картка товару в інвентарі */
    .inventory-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 15px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .inventory-card:hover {
            border-color: var(--neon-blue);
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.1);
            transform: translateX(5px);
        }

    /* Зображення товару */
    .product-img-wrapper {
        background: rgba(0, 0, 0, 0.2);
        padding: 10px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Підсумок (Summary) */
    .summary-panel {
        background: linear-gradient(145deg, rgba(20, 22, 30, 0.9), rgba(10, 12, 18, 0.9));
        border: 1px solid var(--neon-pink);
        border-radius: 20px;
        position: sticky;
        top: 100px;
    }

    /* Кнопки */
    .btn-remove {
        color: #ff4d4d;
        background: transparent;
        border: 1px solid #ff4d4d;
        transition: all 0.2s;
    }

        .btn-remove:hover {
            background: #ff4d4d;
            color: white;
            box-shadow: 0 0 10px rgba(255, 77, 77, 0.4);
        }

    .badge-qty {
        background: var(--neon-blue);
        color: #000;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .total-price {
        color: var(--neon-blue);
        font-family: 'Orbitron', sans-serif;
        font-weight: bold;
    }

    .back-link {
        color: #888;
        text-decoration: none;
        transition: 0.3s;
    }

        .back-link:hover {
            color: var(--neon-blue);
        }
</style>

<div class="container py-4">
    <div class="row g-4">

        <!-- 🔹 ЛІВА ЧАСТИНА (ТОВАРИ) -->
        <div class="col-12 col-lg-8">

            <div class="d-flex align-items-center justify-content-between mb-4 px-2">
                <div>
                    <h2 class="h3 fw-bold mb-0 text-white text-uppercase">Мій Інвентар</h2>
                    <p class="text-secondary small mb-0">
                        Слотів зайнято: @(Model?.Cart?.Lines.Count() ?? 0)
                    </p>
                </div>

                <a asp-action="Index" asp-controller="Shop" class="back-link small">
                    ← Повернутися до магазину
                </a>
            </div>

            @if (!(Model?.Cart?.Lines.Any() ?? false))
            {
                <div class="text-center py-5">
                    <h4 class="text-muted">Тут поки що пусто...</h4>
                </div>
            }

            @foreach (var line in Model?.Cart?.Lines ?? Enumerable.Empty<CartLine>())
            {
                var original = line.Product.Price;
                var discounted = line.GetDiscountedPrice();

                <div class="card mb-3 inventory-card">
                    <div class="card-body">

                        <div class="row align-items-center">

                            <!-- 🔹 ЗОБРАЖЕННЯ -->
                            <div class="col-3 col-md-2">
                                <img src="/products/@line.Product.ImageFileName"
                                     class="img-fluid"
                                     alt="@line.Product.Model" />
                            </div>

                            <!-- 🔹 ІНФО -->
                            <div class="col-6 col-md-7">

                                <h5 class="text-white fw-bold">
                                    @line.Product.BrandName @line.Product.Model
                                </h5>

                                <span class="badge bg-info">x @line.Quantity</span>

                                <!-- 🔹 ЦІНА -->
                                <div class="mt-2">

                                    @if (original != discounted)
                                    {
                                        <span class="text-muted">
                                            <s>@original.ToString("n0") грн</s>
                                        </span>

                                        <span class="text-info ms-2">
                                            @discounted.ToString("n0") грн / од.
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-info">
                                            @original.ToString("n0") грн / од.
                                        </span>
                                    }
                                </div>

                                <!-- 🔹 PROMO -->
                                @if (line.AppliedPromo?.Any() == true)
                                {
                                    <div class="small text-success mt-1">
                                        @foreach (var promo in line.AppliedPromo)
                                        {
                                            <div>
                                                -@Math.Round(promo.DiscountPercentage)% @promo.Name
                                            </div>
                                        }
                                    </div>
                                }

                            </div>

                            <!-- 🔹 СУМА -->
                            <div class="col-3 col-md-3 text-end">

                                <div class="fw-bold text-white fs-5">
                                    @line.GetTotalPrice().ToString("n0") грн
                                </div>

                                <form method="post" asp-action="Remove" asp-controller="Cart">
                                    <input type="hidden" name="id" value="@line.Product.Id" />
                                    <input type="hidden" name="returnUrl" value="@Model?.ReturnUrl" />

                                    <button class="btn btn-sm btn-danger mt-2">
                                        Видалити
                                    </button>
                                </form>

                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- 🔹 ПРАВА ЧАСТИНА (SUMMARY) -->
        <div class="col-12 col-lg-4">

            <div class="card summary-panel p-4">

                

                <!-- 🔹 BASE (з урахуванням promo) -->
                <div class="d-flex justify-content-between text-secondary mb-2">
                    <h5 class="text-white text-center mb-4">
                        Загальна сума
                    </h5>
                    <span>
                        @(Model?.Pricing?.OriginalPrice.ToString("n0")
                          ?? Model?.Cart?.ComputeTotalValue().ToString("n0")) грн
                    </span>
                </div>
                
                <div class="d-flex justify-content-between text-secondary mb-2">
                    <span>Знижки</span>
                    @{
                        decimal? discount = null;

                        if (Model?.Cart != null)
                        {
                            discount = Model.Cart.ComputeTotalValueWithLinePromos()
                                     - Model.Cart.ComputeTotalValue();
                        }
                    }

                    <span>@(discount?.ToString("n0") ?? "0") грн</span>
                </div>

                <!-- 🔹 DISCOUNTS -->
                @if (Model?.Pricing?.AppliedDiscounts?.Count() >= 1)
                {
                    <div class="mb-3">
                        <h6 class="text-secondary small">Додаткові знижки</h6>

                        @foreach (var d in Model.Pricing.AppliedDiscounts)
                        {
                            <div class="d-flex justify-content-between small">
                                <span>@d.Name</span>
                                <span class="text-danger">-@d.Amount.ToString("n0") грн</span>
                            </div>
                        }
                    </div>
                }

                <hr />

                <!-- 🔹 FINAL -->
                <div class="d-flex justify-content-between">
                    <span class="text-white">До сплати</span>
                    <span class="text-info fs-4 fw-bold">
                        @(Model?.Pricing?.FinalPrice.ToString("n0")) грн
                    </span>
                </div>

                <!-- 🔹 BUTTON -->
                <div class="mt-4">
                    <a asp-action="Checkout" asp-controller="Order"
                           class="btn btn-success w-100">
                        Оформити замовлення
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>
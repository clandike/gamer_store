@using GamerStore.Services
@using GamerStore.Models.DTO

@model List<OrderDTO>
@inject IOrderService OrderService

<table class="table table-sm table-striped table-bordered">
    <thead>
        <tr>
            <th colspan="6" class="text-center">Orders</th>
        </tr>
        <tr>
            <th>Customer</th>
            <th>Address</th>
            <th>Products</th>
            <th>Total</th>
            <th>Status</th>
            <th>Change Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var order in Model)
            {
                var allowedStatuses = OrderService.GetAllowedStatuses(order.Status);

                <tr>
                    <td>
                        <div>@order.CustomerInfo.Name</div>
                        <div class="text-muted small">@order.CustomerInfo.Email</div>
                        <div class="text-muted small">@order.CustomerInfo.Phone</div>
                    </td>
                    <td>
                        <div>@order.CustomerInfo.Address</div>
                        <div class="text-muted small">
                            @order.CustomerInfo.City, @order.CustomerInfo.Zip
                        </div>
                        <div class="text-muted small">@order.CustomerInfo.Country</div>
                    </td>
                    <td>
                        @foreach (var item in order.OrderInfoDTOs)
                        {
                            <div>
                                @item.ProductName
                                <span class="text-muted small">× @item.Quantity</span>
                                @if (order.GiftWrap)
                                {
                                    <span class="badge bg-warning text-dark ms-1">🎁 Gift</span>
                                }
                            </div>
                        }
                    </td>
                    <td>@order.Total.ToString("C")</td>
                    <td>
                        <span class="badge @GetStatusBadgeClass(order.Status)">
                            @order.Status
                        </span>
                    </td>
                    <td>
                        @if (allowedStatuses.Length > 0)
                        {
                            <form asp-controller="Order"
                                  asp-action="ChangeStatus"
                                  method="post"
                                  class="d-flex gap-2">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <select name="newStatus" class="form-select form-select-sm">
                                    @foreach (var status in allowedStatuses)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">
                                    Apply
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted small">No transitions</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="6" class="text-center">No Orders</td></tr>
        }
    </tbody>
</table>

@functions {
    string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-secondary",
        OrderStatus.Confirmed => "bg-info text-dark",
        OrderStatus.Processing => "bg-warning text-dark",
        OrderStatus.Shipped => "bg-primary",
        OrderStatus.Delivered => "bg-success",
        OrderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
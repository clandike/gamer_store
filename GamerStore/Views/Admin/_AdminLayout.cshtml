<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MotoEquip Admin</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f6f8;
            margin: 0;
        }

        .navbar {
            background: linear-gradient(to right, #0061ff, #60efff);
            color: white;
        }

        .navbar-brand {
            font-weight: 600;
            font-size: 1.3rem;
        }

        .admin-layout {
            display: flex;
            height: calc(100vh - 56px);
        }

        .sidebar {
            width: 240px;
            background-color: #1e1e2f;
            color: #fff;
            display: flex;
            flex-direction: column;
            padding: 1rem;
        }

            .sidebar a {
                color: #bdbdbd;
                text-decoration: none;
                margin-bottom: 1rem;
                display: flex;
                align-items: center;
                font-size: 0.95rem;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    color: #ffffff;
                }

                .sidebar a i {
                    margin-right: 10px;
                }

        .main-content {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .logout-btn {
            color: white;
            border: 1px solid #fff;
        }
    </style>
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <a class="navbar-brand" href="#">MotoEquip Admin</a>
        <div class="ms-auto">
            <a class="btn btn-sm logout-btn" asp-controller="Account" asp-action="Login">Log Out</a>
        </div>
    </nav>

    <!-- Layout -->
    <div class="admin-layout">
        <!-- Sidebar -->
        <div class="sidebar">
            <vc:admin-navigation-menu class="bi bi-box-seam" />
        </div>

        <!-- Main Content -->
        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <script src="/lib/jquery/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@using GamerStore.Infrastructure
@using GamerStore.Models.ViewModels
@using GamerStore.Models.DTO;
@model (ProductDTO Product, string ThemeColor, string TitleText, string CallbackMethodName)

@{
    ProductDTO product = Model.Product;
}

<h3 class="bg-@Model.ThemeColor text-white text-center p-1">@Model.TitleText a Product</h3>
<div class="row">

    @{
        if (Model.CallbackMethodName != "Create")
        {
            <div class="col-md-4 text-center">
                <img src="~/products/@Model.Product.ImageFileName" class="img-fluid rounded border" alt="Product Image" style="max-height: 400px;" />
            </div>
        }
    }

    <div class="col-md-8">
        <form asp-action="@Model.CallbackMethodName" asp-controller="Admin" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (Model.Product.Id != 0)
            {
                <div class="form-group">
                    <label class="control-label">Id</label>
                    <input asp-for="Product.Id" name="Id" class="form-control" readonly />
                </div>
            }

            <div class="form-group">
                <label class="control-label">Brand</label>
                <input asp-for="Product.BrandId" name="BrandId" class="form-control" />
                <span asp-validation-for="Product.BrandId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Model</label>
                <input asp-for="Product.Model" name="Model" class="form-control" />
                <span asp-validation-for="Product.Model" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Title</label>
                <input asp-for="Product.Title" name="Title" class="form-control" />
                <span asp-validation-for="Product.Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Category</label>
                <input asp-for="Product.CategoryId" name="CategoryId" class="form-control" />
                <span asp-validation-for="Product.CategoryName"  class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Image File</label>
                <input asp-for="Product.ImageFileName" name="ImageFileName" class="form-control" />
                <span asp-validation-for="Product.ImageFileName"  class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Is in stock</label>
                <select asp-for="Product.IsInStock" name="IsInStock" class="form-control">
                    <option value="1">Так</option>
                    <option value="0">Ні</option>
                </select>
                <span asp-validation-for="Product.IsInStock"  class="text-danger"></span>
            </div>


            <div class="form-group">
                <label class="control-label">Price</label>
                <input asp-for="Product.Price" name="Price" class="form-control" />
                <span asp-validation-for="Product.Price"  class="text-danger"></span>
            </div>
            @{
                string returnValue = Model.CallbackMethodName;
            }

            <div class="mt-2">
                <button asp-action="@Model.CallbackMethodName" type="submit" class="btn btn-@Model.ThemeColor">
                    Save
                </button>
                <a class="btn btn-secondary" asp-controller="Admin" asp-action="Products">Cancel</a>
            </div>
        </form>
    </div>
</div>
